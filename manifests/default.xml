<?xml version="1.0" encoding="UTF-8"?>
<!--
  Repo manifest for Rockchip Linux SDK (simplified, open-source sources).

  All repositories point to official public mirrors where available.
  Proprietary binaries (rkbin) still come from Rockchip's own GitHub.

  Usage:
    mkdir rksdk && cd rksdk
    repo init -u git@github.com:TommasoLabieni/rksdk -b master -m manifests/default.xml
    repo sync -j8
-->
<manifest>

  <!-- ============================================================
       Default remote / revision
       ============================================================ -->
  <default remote="github" revision="refs/heads/master" sync-j="4"/>

  <!-- ============================================================
       Remotes
       ============================================================ -->

  <!-- Public repos via HTTPS -->
  <remote name="github"
          fetch="https://github.com"
          review="https://github.com"/>

  <!-- Private repos via SSH (requires SSH key configured for GitHub) -->
  <remote name="github-ssh"
          fetch="ssh://git@github.com"
          review="https://github.com"/>

  <!-- ============================================================
       Build system (this SDK repo) — synced to workspace root.
       Uses SSH because the repo is private.
       ============================================================ -->
  <project name="TommasoLabieni/rksdk"
           path="."
           remote="github-ssh"
           revision="refs/heads/master"
           clone-depth="1"/>

  <!-- ============================================================
       Kernel — Rockchip downstream 6.1 (open source, GitHub mirror)
       ============================================================ -->
  <project name="rockchip-linux/kernel"
           path="kernel-6.1"
           remote="github"
           revision="refs/heads/develop-6.1"
           clone-depth="1"/>

  <!-- ============================================================
       U-Boot — Rockchip downstream (open source, GitHub mirror)
       ============================================================ -->
  <project name="rockchip-linux/u-boot"
           path="u-boot"
           remote="github"
           revision="refs/heads/next-dev"
           clone-depth="1"/>

  <!-- ============================================================
       rkbin — Rockchip proprietary binaries (BL31, DDR init, etc.)
       No open-source alternative exists for these blobs.
       ============================================================ -->
  <project name="rockchip-linux/rkbin"
           path="rkbin"
           remote="github"
           revision="refs/heads/master"
           clone-depth="1"/>

  <!-- ============================================================
       RT-Thread RTOS (open source) — used for AMP co-processing
       ============================================================ -->
  <project name="RT-Thread/rt-thread"
           path="rtos"
           remote="github"
           revision="refs/heads/master"
           clone-depth="1"/>

  <!-- ============================================================
       HAL — Rockchip bare-metal HAL for AMP co-processing.
       Not available on public GitHub. Obtain from the official
       Rockchip Linux SDK release package and place in hal/.
       ============================================================ -->
  <!-- <project name="rockchip-linux/hal" path="hal" remote="github"/> -->

  <!-- ============================================================
       Yocto — meta layers
       ============================================================ -->
  <!-- Poky (OpenEmbedded reference distro) -->
  <project name="yoctoproject/poky"
           path="yocto/poky"
           remote="github"
           revision="refs/heads/scarthgap"
           clone-depth="1"/>

  <!-- OpenEmbedded meta layers -->
  <project name="openembedded/meta-openembedded"
           path="yocto/meta-openembedded"
           remote="github"
           revision="refs/heads/scarthgap"
           clone-depth="1"/>

  <!-- Rockchip Yocto BSP layer — maintained by Rockchip engineer Jeffy Chen -->
  <project name="JeffyCN/meta-rockchip"
           path="yocto/meta-rockchip"
           remote="github"
           revision="refs/heads/scarthgap"
           clone-depth="1"/>

  <!-- ============================================================
       Tools — Rockchip open-source USB flash tool
       ============================================================ -->
  <project name="rockchip-linux/rkdeveloptool"
           path="tools"
           remote="github"
           revision="refs/heads/master"
           clone-depth="1"/>

  <!-- ============================================================
       UEFI — No single public Rockchip EDK2 repo covers all chips.
       Chip-specific community forks:
         rk3588: https://github.com/edk2-porting/edk2-rk3588
         rk3576: https://github.com/gahingwoo/edk2-rk3576
       Obtain and place in uefi/ manually if needed.
       ============================================================ -->
  <!-- <project name="edk2-porting/edk2-rk3588" path="uefi" remote="github"/> -->

  <!-- ============================================================
       Prebuilt toolchains
       Not managed by repo — too large for git.
       Download Arm GNU Toolchain from:
         https://developer.arm.com/downloads/-/arm-gnu-toolchain-downloads
       and unpack to prebuilts/gcc/linux-x86/aarch64/
       ============================================================ -->

</manifest>
